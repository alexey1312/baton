#!/bin/sh
# Pre-commit hook — runs linters with auto-fix via hk (delegated through mise).
# Skip with: HK=0. Also skipped during rebase.
test "${HK:-1}" = "0" && exit 0
test -d "$(git rev-parse --git-dir)/rebase-merge" 2>/dev/null && exit 0
test -d "$(git rev-parse --git-dir)/rebase-apply" 2>/dev/null && exit 0

if ! command -v mise >/dev/null 2>&1; then
    echo "hk: mise not found on PATH; skipping pre-commit hooks (install mise or set HK=0)" >&2
    exit 0
fi

exec mise x -- hk run --silent pre-commit "$@"
